  clips:
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: bed7478a90a81034487b01a6fbd270ea, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3.88
      text: "Il fait tr\xE8s sombre ici, faites attention o\xF9 vous mettez les pieds.\n"
      characterCount: 68
      delayBetweenLines: 0
      soundID:
        ID: 1342177567
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 4.4
      text: "La lumi\xE8re fait d\xE9faut ici... Faites attention les un aux autres."
      characterCount: 65
      delayBetweenLines: 0
      soundID:
        ID: 1342177568
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 6907ab4dd1948334eabe022b53c8b49d, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3.1
      text: "Alli\xE9s, je crains que ma vision ait fortement r\xE9duite.\n"
      characterCount: 55
      delayBetweenLines: 0
      soundID:
        ID: 1342177704
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 2.9
      text: "Cela me rendrait ravie de poss\xE9der plus de lumi\xE8re."
      characterCount: 51
      delayBetweenLines: 0
      soundID:
        ID: 1342177705
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 8538becf3d7dff243b44f593a4e788a8, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 2.7
      text: "On voit rien dans ce trou pomm\xE9 s\xE9rieux...\n"
      characterCount: 43
      delayBetweenLines: 0
      soundID:
        ID: 1342177333
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 4
      text: "Fait chier ! J'ai march\xE9 dans un truc gluant et en plus j'vois que
        dalle !"
      characterCount: 74
      delayBetweenLines: 0
      soundID:
        ID: 1342177334
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 464e9e9c5413d1340bd1934a0c4149f5, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3.6
      text: 'Waaaaahou ! Il fait pas qu''un peu sombre ici.

'
      characterCount: 46
      delayBetweenLines: 0
      soundID:
        ID: 1342177462
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 6.3
      text: J'SUIS DEVENU AVEUGLE. NON J'SUIS DEVENU AVEUGLE ! Ah non. Non non, c'est
        juste qu'il fait sombre.
      characterCount: 98
      delayBetweenLines: 0
      soundID:
        ID: 1342177463
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
