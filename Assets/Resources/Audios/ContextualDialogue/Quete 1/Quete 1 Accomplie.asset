      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 6907ab4dd1948334eabe022b53c8b49d, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 0
      text: "La Trinitite est en s\xE9curit\xE9.\n"
      characterCount: 30
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 0
      text: "La t\xE2che est achev\xE9e, les \xE9nergies se sont calm\xE9es."
      characterCount: 51
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 8538becf3d7dff243b44f593a4e788a8, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 0
      text: "Quel job de merde s\xE9rieux.\n"
      characterCount: 27
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 0
      text: "C'est quel genre de job \xE7a...\n"
      characterCount: 30
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 0
      text: "Mission accomplie... Et \xE0 MOI le m\xE9rite."
      characterCount: 40
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 464e9e9c5413d1340bd1934a0c4149f5, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 0
      text: "Quelques explosions supl\xE9mentaires m'auraient pas d\xE9rang\xE9es.\n"
      characterCount: 61
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 0
      text: "Si ils vous reste des grenades et que vous voulez vous en d\xE9barrasser,
        je suis votre homme."
      characterCount: 91
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
