  clips:
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: bed7478a90a81034487b01a6fbd270ea, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3.3
      text: 'Mission accomplie, je suis fier de vous.

'
      characterCount: 41
      delayBetweenLines: 0
      soundID:
        ID: 1342177569
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 2.2
      text: Et une autre mission accomplie.
      characterCount: 31
      delayBetweenLines: 0
      soundID:
        ID: 1342177570
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 6907ab4dd1948334eabe022b53c8b49d, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 2.6
      text: "La Trinitite est en s\xE9curit\xE9.\n"
      characterCount: 30
      delayBetweenLines: 0
      soundID:
        ID: 1342177706
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3.3
      text: "La t\xE2che est achev\xE9e, les \xE9nergies se sont calm\xE9es."
      characterCount: 51
      delayBetweenLines: 0
      soundID:
        ID: 1342177707
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 8538becf3d7dff243b44f593a4e788a8, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 2.2
      text: "Quel job de merde s\xE9rieux.\n"
      characterCount: 27
      delayBetweenLines: 0
      soundID:
        ID: 1342177335
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 2.4
      text: "C'est quel genre de boulot \xE7a !\n"
      characterCount: 32
      delayBetweenLines: 0
      soundID:
        ID: 1342177336
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 4
      text: "Mission accomplie... Et \xE0 moi le m\xE9rite."
      characterCount: 40
      delayBetweenLines: 0
      soundID:
        ID: 1342177337
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 464e9e9c5413d1340bd1934a0c4149f5, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 4.1
      text: "Oooh... Quelques explosions supl\xE9mentaires ne m'auraient pas d\xE9rang\xE9es.\n"
      characterCount: 72
      delayBetweenLines: 0
      soundID:
        ID: 1342177464
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 5
      text: "Si ils vous restent des grenades et que vous voulez vous en d\xE9barrasser,
        je suis votre homme."
      characterCount: 93
      delayBetweenLines: 0
      soundID:
        ID: 1342177465
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
