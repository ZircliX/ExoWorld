  clips:
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: bed7478a90a81034487b01a6fbd270ea, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 2.4
      text: "Pr\xEAt \xE0 prot\xE8ger ceux dans le besoin."
      characterCount: 36
      delayBetweenLines: 0
      soundID:
        ID: 1342177593
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 2.2
      text: Je devrai garder un oeil sur Pearl.
      characterCount: 35
      delayBetweenLines: 0
      soundID:
        ID: 1342177594
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 6907ab4dd1948334eabe022b53c8b49d, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3
      text: Que nos chemins se solidarisent, sous ce nouveau ciel.
      characterCount: 54
      delayBetweenLines: 0
      soundID:
        ID: 1342177730
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 4.3
      text: "Cela est un honneur. D'o\xF9 je viens, je fais ce qui est de meilleur
        pour tous."
      characterCount: 77
      delayBetweenLines: 0
      soundID:
        ID: 1342177731
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 8538becf3d7dff243b44f593a4e788a8, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 2.9
      text: "Enfin un peu d'action, je commen\xE7ais \xE0 m'ennuyer...\n"
      characterCount: 52
      delayBetweenLines: 0
      soundID:
        ID: 1342177369
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 2.7
      text: "Enfin un membre utile dans cette \xE9quipe de bras-cass\xE9s.\n"
      characterCount: 56
      delayBetweenLines: 0
      soundID:
        ID: 1342177370
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 2.4
      text: "Je vais encore me taper tout le sale boulot c'est \xE7a?"
      characterCount: 53
      delayBetweenLines: 0
      soundID:
        ID: 1342177371
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3.2
      text: "Je vais encore me taper tout le sale boulot c'est \xE7a?"
      characterCount: 53
      delayBetweenLines: 0
      soundID:
        ID: 1342177372
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 464e9e9c5413d1340bd1934a0c4149f5, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3.6
      text: "Moi moi moi, j'suis l\xE0 ! Et j'suis pr\xEAt \xE0 tout faire p\xE9ter
        !\n"
      characterCount: 61
      delayBetweenLines: 0
      soundID:
        ID: 1342177491
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 5.4
      text: "Un peu plus et je restais sur le banc de touche. QUI aurait tout fait
        p\xE9ter si j'\xE9tais pas l\xE0 ?"
      characterCount: 95
      delayBetweenLines: 0
      soundID:
        ID: 1342177492
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
