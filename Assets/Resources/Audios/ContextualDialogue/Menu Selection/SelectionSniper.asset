  clips:
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: bed7478a90a81034487b01a6fbd270ea, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 2.5
      text: "Prendre de la distance peut \xEAtre une bonne id\xE9e.\n"
      characterCount: 49
      delayBetweenLines: 0
      soundID:
        ID: 1342177587
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 4
      text: "Puissance et pr\xE9cison... un bon choix."
      characterCount: 38
      delayBetweenLines: 0
      soundID:
        ID: 1342177588
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 6907ab4dd1948334eabe022b53c8b49d, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 4.6
      text: "Je pr\xE9f\xE8re r\xE9fl\xE9chir longuement, plut\xF4t que de solutionner
        trop vite.\n"
      characterCount: 70
      delayBetweenLines: 0
      soundID:
        ID: 1342177724
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 4
      text: Je choisi de rester loin pour conserver ce qui est proche.
      characterCount: 58
      delayBetweenLines: 0
      soundID:
        ID: 1342177725
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 8538becf3d7dff243b44f593a4e788a8, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 2.3
      text: 'Le meilleur choix, pour le meilleur membre.

'
      characterCount: 44
      delayBetweenLines: 0
      soundID:
        ID: 1342177361
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 4.5
      text: "Un mod\xE8le Z-890 ? Vous l'avez vol\xE9 celui l\xE0 non ?"
      characterCount: 49
      delayBetweenLines: 0
      soundID:
        ID: 1342177363
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 464e9e9c5413d1340bd1934a0c4149f5, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3
      text: "Euh, quelqu'un sait si j'peux le garder apr\xE8s la mission ?\n"
      characterCount: 59
      delayBetweenLines: 0
      soundID:
        ID: 1342177482
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3.1
      text: Toi t'es mieux entre mes mains, qu'entre les mains de mes enemis.
      characterCount: 65
      delayBetweenLines: 0
      soundID:
        ID: 1342177483
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
