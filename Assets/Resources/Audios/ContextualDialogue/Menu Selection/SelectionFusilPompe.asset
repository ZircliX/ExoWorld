  clips:
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: bed7478a90a81034487b01a6fbd270ea, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 4.3
      text: "Vous n'avez que \xE7a en stock ! Bon... je vais faire avec."
      characterCount: 56
      delayBetweenLines: 0
      soundID:
        ID: 1342177589
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 1.8
      text: "Mieux vaut \xEAtre bien \xE9quip\xE9."
      characterCount: 28
      delayBetweenLines: 0
      soundID:
        ID: 1342177590
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 6907ab4dd1948334eabe022b53c8b49d, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3.4
      text: "La force sera employ\xE9e... mais sans animosit\xE9.\n"
      characterCount: 47
      delayBetweenLines: 0
      soundID:
        ID: 1342177726
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 5.8
      text: "Cet arsenal me provoque d'\xE9trange sentiments. Serait-ce ce qu'on
        appelle : joie ?"
      characterCount: 81
      delayBetweenLines: 0
      soundID:
        ID: 1342177727
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 8538becf3d7dff243b44f593a4e788a8, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 2.7
      text: 'Simple, efficace, tout comme moi quoi.

'
      characterCount: 39
      delayBetweenLines: 0
      soundID:
        ID: 1342177364
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3.7
      text: "Le premier qui me fait chier va go\xFBter \xE0 ce bijou."
      characterCount: 50
      delayBetweenLines: 0
      soundID:
        ID: 1342177365
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 464e9e9c5413d1340bd1934a0c4149f5, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 2.5
      text: 'Toiiiiiii, j''t''aime bien !

'
      characterCount: 27
      delayBetweenLines: 0
      soundID:
        ID: 1342177484
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3.5
      text: "Gros comme \xE7a, si \xE7a explose pas je ne m'y connais pas."
      characterCount: 55
      delayBetweenLines: 0
      soundID:
        ID: 1342177486
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 2.4
      text: 'Toi, hmm... j''t''aime bien.

'
      characterCount: 27
      delayBetweenLines: 0
      soundID:
        ID: 1342177485
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
