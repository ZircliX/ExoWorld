  clips:
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: bed7478a90a81034487b01a6fbd270ea, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 0
      text: "On devrait se d\xE9barasser du gaz avant de continuer.\n"
      characterCount: 52
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 0
      text: "Il ne vaut mieux pas qu'on continue temps que le gaz est l\xE0."
      characterCount: 60
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 6907ab4dd1948334eabe022b53c8b49d, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 0
      text: "Je ressens que cette fum\xE9e verd\xE2tre n'est pas sain.\n"
      characterCount: 52
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 0
      text: J'ai la connaissance que ce genre de petites germes ne viennent jamais
        seules...
      characterCount: 80
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 8538becf3d7dff243b44f593a4e788a8, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 0
      text: 'Hm... Les amis, c''est quoi ce truc au sol ?

'
      characterCount: 44
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 0
      text: "Ugh.. J'ai mes pieds qui touchent ce truc pourri au sol l\xE0.\n"
      characterCount: 60
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 0
      text: "Ok \xE7a me d\xE9go\xFBte. J'avance pas tant que ce truc vert ait pas
        disparu."
      characterCount: 69
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 464e9e9c5413d1340bd1934a0c4149f5, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 0
      text: 'Je sais pas ce que c''est comme gaz et je veux pas savoir.

'
      characterCount: 58
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 0
      text: "Si je respire \xE7a je vais clamser, ... donc je respire pas \xE7a."
      characterCount: 61
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
