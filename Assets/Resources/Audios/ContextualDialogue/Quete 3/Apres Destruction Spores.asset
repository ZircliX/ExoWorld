  m_Name: Apres Destruction Spores
  m_EditorClassIdentifier: OverBang.ExoWorld.Core::OverBang.ExoWorld.Core.Audios.ContextualDialogues.ContextualDialogueData
  <ID>k__BackingField: 0d1df57c-ceed-4d05-be52-bcbb7e8e1fbd
  <Priority>k__BackingField: 2
  <Probability>k__BackingField: 1
