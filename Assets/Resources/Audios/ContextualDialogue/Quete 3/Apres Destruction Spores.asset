  clips:
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: bed7478a90a81034487b01a6fbd270ea, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3
      text: 'Il y a toujours du gaz, on ferait mieux de ne pas avancer.

'
      characterCount: 59
      delayBetweenLines: 0
      soundID:
        ID: 1342177573
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 2.7
      text: Encore du gaz, il ne vaut mieux pas avancer.
      characterCount: 44
      delayBetweenLines: 0
      soundID:
        ID: 1342177574
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 6907ab4dd1948334eabe022b53c8b49d, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3.8
      text: "Je visualise que toute la fum\xE9e verd\xE2tre ne s'est  pas dissip\xE9e
        partout.\n"
      characterCount: 73
      delayBetweenLines: 0
      soundID:
        ID: 1342177709
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 2.6
      text: Je crains que je ne puisse franchir le gaz restant.
      characterCount: 51
      delayBetweenLines: 0
      soundID:
        ID: 1342177710
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 8538becf3d7dff243b44f593a4e788a8, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 4.8
      text: "Bon bah super \xE7a, y'a encore ce gaz de merde ici. Moi j'y vais pas.\n"
      characterCount: 68
      delayBetweenLines: 0
      soundID:
        ID: 1342177341
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3.8
      text: Moi je mets pas un pied dans ce brouillard de gaz infect.
      characterCount: 57
      delayBetweenLines: 0
      soundID:
        ID: 1342177342
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 464e9e9c5413d1340bd1934a0c4149f5, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 4
      text: 'Du gaz, encore du gaz, pas moyen d''aller plus loin.

'
      characterCount: 52
      delayBetweenLines: 0
      soundID:
        ID: 1342177468
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 6.2
      text: "On ne peut toujours pas avancer, il y a encore du gaz.. D\xE9\xE7u,
        vraiment d\xE9\xE7u."
      characterCount: 76
      delayBetweenLines: 0
      soundID:
        ID: 1342177469
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
