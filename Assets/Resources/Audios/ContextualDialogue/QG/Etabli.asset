  clips:
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: bed7478a90a81034487b01a6fbd270ea, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 2.2
      text: "L'am\xE9lioration \xE7a me connait.\n"
      characterCount: 30
      delayBetweenLines: 0
      soundID:
        ID: 1342177536
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3.1
      text: "Il y a toujours moyen d'am\xE9liorer son \xE9quipement.\n"
      characterCount: 50
      delayBetweenLines: 0
      soundID:
        ID: 1342177537
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3.3
      text: "Je ne me pleindrai jamais d'avoir un \xE9tabli sous la main."
      characterCount: 57
      delayBetweenLines: 0
      soundID:
        ID: 1342177538
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 6907ab4dd1948334eabe022b53c8b49d, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3.2
      text: "D'o\xF9 je viens, la cr\xE9ation est substentielle.\n"
      characterCount: 46
      delayBetweenLines: 0
      soundID:
        ID: 1342177631
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 4.7
      text: "Toutes ces ressources me comblent de bonheur, je me per\xE7ois comme
        chez moi."
      characterCount: 75
      delayBetweenLines: 0
      soundID:
        ID: 1342177632
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 8538becf3d7dff243b44f593a4e788a8, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 2.1
      text: "La bricole c'est pas mon d\xE9lire en fait."
      characterCount: 40
      delayBetweenLines: 0
      soundID:
        ID: 1342177281
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3.6
      text: "Si j'veux pr\xE9server ce beau corps, va falloir bien s'\xE9quiper.\n"
      characterCount: 62
      delayBetweenLines: 0
      soundID:
        ID: 1342177282
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3.5
      text: "La survie \xE7a se m\xE9rite. Et... se fabrique."
      characterCount: 42
      delayBetweenLines: 0
      soundID:
        ID: 1342177283
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 464e9e9c5413d1340bd1934a0c4149f5, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 7.5
      text: "Si j'\xE9tais inventeur, j'inventerai de la poudre encore plus explosive
        ! Mais bon, j'suis juste Spikey.\n"
      characterCount: 103
      delayBetweenLines: 0
      soundID:
        ID: 1342177420
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 4.2
      text: "Euuh, je ne vois pas l'am\xE9lioration des grenades, quelqu'un sait
        o\xF9 elle est ?\n"
      characterCount: 79
      delayBetweenLines: 0
      soundID:
        ID: 1342177421
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3.6
      text: CLANK PAF BVVVVV CLONK !
      characterCount: 24
      delayBetweenLines: 0
      soundID:
        ID: 1342177422
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
