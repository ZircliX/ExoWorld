  clips:
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: bed7478a90a81034487b01a6fbd270ea, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 0
      text: "L'am\xE9lioration \xE7a me connait.\n"
      characterCount: 30
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 0
      text: "Il y a toujours moyen d'am\xE9liorer son \xE9quipement.\n"
      characterCount: 50
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 0
      text: "Je ne me pleindrai jamais d'avoir un \xE9tabli sous la main."
      characterCount: 57
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 6907ab4dd1948334eabe022b53c8b49d, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 0
      text: "D'o\xF9 je viens, la cr\xE9ation est substentielle.\n"
      characterCount: 46
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 0
      text: "Toutes ces ressources me comblent de bonheur, je me per\xE7ois comme
        chez moi."
      characterCount: 75
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 8538becf3d7dff243b44f593a4e788a8, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 0
      text: "La bricole c'est pas mon d\xE9lire en fait."
      characterCount: 40
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 0
      text: "Si je veux pr\xE9server ce beau corps, va falloir bien s'\xE9quiper.\n"
      characterCount: 63
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 0
      text: "La survie \xE7a se m\xE9rite... et se fabrique."
      characterCount: 41
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 464e9e9c5413d1340bd1934a0c4149f5, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 0
      text: "Si j'\xE9tais inventeur j'inventerai de la poudre encore plus explosive,
        mais bon j'suis juste Spikey.\n"
      characterCount: 100
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 0
      text: "Je ne vois pas l'am\xE9lioration des grenades, quelqu'un sait o\xF9
        elle est ?\n"
      characterCount: 73
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 0
      text: CLANK CLANK CLONK
      characterCount: 17
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
