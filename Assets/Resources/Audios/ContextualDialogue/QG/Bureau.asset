        ID: 1342177635
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 8538becf3d7dff243b44f593a4e788a8, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 1.8
      text: "Alors il dit quoi d'beau celui l\xE0 ?"
      characterCount: 35
      delayBetweenLines: 0
      soundID:
        ID: 1342177284
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 2.2
      text: "Heureusement qu'y'a au moins \xE7a qui marche ici..."
      characterCount: 49
      delayBetweenLines: 0
      soundID:
        ID: 1342177286
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3.1
      text: "Waa... Y'a un paquet d'infos l\xE0 d'dans quand m\xEAme."
      characterCount: 50
      delayBetweenLines: 0
      soundID:
        ID: 1342177287
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
