  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 464e9e9c5413d1340bd1934a0c4149f5, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3
      text: "Attteennndddeeezz... Ok c'est bon, j'suis pr\xEAt \xE0 vous r\xE8gler
        votre compte.\n"
      characterCount: 75
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3
      text: "Pause tactique pour Spikey, de retour tr\xE8s vite ne vous en faites
        pas.\n"
      characterCount: 71
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3
      text: "Laisse moi me rapeller dans quel sens \xE7a va et je suis \xE0 toi."
      characterCount: 61
      delayBetweenLines: 0
      soundID:
        ID: 0
