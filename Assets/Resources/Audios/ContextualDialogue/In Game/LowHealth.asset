  clips:
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: bed7478a90a81034487b01a6fbd270ea, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3.1
      text: 'Je n''ai pas le droit de tomber, elle compte sur moi.

'
      characterCount: 53
      delayBetweenLines: 0
      soundID:
        ID: 1342177610
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 4
      text: "Pas bon du tout \xE7a, mais alors pas bon du tout.\n"
      characterCount: 48
      delayBetweenLines: 0
      soundID:
        ID: 1342177611
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3
      text: "Va peut \xEAtre falloir calmer la cadence."
      characterCount: 39
      delayBetweenLines: 0
      soundID:
        ID: 1342177612
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 6907ab4dd1948334eabe022b53c8b49d, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3.5
      text: "Mes forces s'\xE9teignent... j'ai besoin de votre lumi\xE8re.\n"
      characterCount: 56
      delayBetweenLines: 0
      soundID:
        ID: 1342177751
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 4.1
      text: 'Faiblesse approche... je requiers votre assistance.

'
      characterCount: 52
      delayBetweenLines: 0
      soundID:
        ID: 1342177752
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3
      text: "J'ai le sentiment que mes m\xE9dicaments n'ont plus d'atteinte."
      characterCount: 60
      delayBetweenLines: 0
      soundID:
        ID: 1342177753
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 8538becf3d7dff243b44f593a4e788a8, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3
      text: "Je me sens pas tr\xE8s bien l\xE0...\n"
      characterCount: 31
      delayBetweenLines: 0
      soundID:
        ID: 1342177396
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3.7
      text: "C'est quand qu'on rentre s\xE9rieux ? Je me sens bizarre...\n"
      characterCount: 57
      delayBetweenLines: 0
      soundID:
        ID: 1342177397
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 5.4
      text: "Je me suis jamais sentie aussi vivante ! Je rigole... JE PISSE LE SANG
        L\xC0 !"
      characterCount: 75
      delayBetweenLines: 0
      soundID:
        ID: 1342177398
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 464e9e9c5413d1340bd1934a0c4149f5, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 5.7
      text: "Les amis, j'ai une confession \xE0 vous faire : j'suis vraiment dans
        la merde.\n"
      characterCount: 76
      delayBetweenLines: 0
      soundID:
        ID: 1342177513
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 5
      text: 'Je sens plus mes jambes et dans pas longtemps, je sentirai plus rien.

'
      characterCount: 70
      delayBetweenLines: 0
      soundID:
        ID: 1342177514
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 5
      text: 'Je sens plus mes jambes et dans pas longtemps, je sentirai plus rien.

'
      characterCount: 70
      delayBetweenLines: 0
      soundID:
        ID: 1342177515
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 5.7
      text: "Faut se calmer Spikey, sinon tu pourras plus rien faire p\xE9ter, et
        \xE7a, \xE7a fait vraiment chier !!\n"
      characterCount: 96
      delayBetweenLines: 0
      soundID:
        ID: 1342177516
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
