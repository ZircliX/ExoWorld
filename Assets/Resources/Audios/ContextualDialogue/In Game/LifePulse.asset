  - <CharacterData>k__BackingField: {fileID: 11400000, guid: bed7478a90a81034487b01a6fbd270ea, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3
      text: "\xC7a ne peut pas faire de mal.\n"
      characterCount: 29
      delayBetweenLines: 0
      soundID:
        ID: 1342177552
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3
      text: 'Un petit coup de boost, je ne dit pas non.

'
      characterCount: 43
      delayBetweenLines: 0
      soundID:
        ID: 1342177553
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3
      text: "Ahhh, \xC7a fait du bien."
      characterCount: 22
      delayBetweenLines: 0
      soundID:
        ID: 1342177554
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 6907ab4dd1948334eabe022b53c8b49d, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3.1
      text: 'Cela apaise mes plus profondes blessures.

'
      characterCount: 42
      delayBetweenLines: 0
      soundID:
        ID: 1342177661
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3
      text: "L'\xE9nergie circule \xE0 nouveau dans mon \xEAtre."
      characterCount: 42
      delayBetweenLines: 0
      soundID:
        ID: 1342177662
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3.2
      text: "L'\xE9nergie circule \xE0 nouveau dans mon \xEAtre."
      characterCount: 42
      delayBetweenLines: 0
      soundID:
        ID: 1342177663
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 8538becf3d7dff243b44f593a4e788a8, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3
      text: 'Pas que j''en ai besoin... mais on sait jamais.

'
      characterCount: 47
      delayBetweenLines: 0
      soundID:
        ID: 1342177303
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3
      text: 'Pas que j''en ai besoin... mais on sait jamais.

'
      characterCount: 47
      delayBetweenLines: 0
      soundID:
        ID: 1342177304
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3
      text: "J'esp\xE8re que \xE7'truc marche vraiment...\n"
      characterCount: 39
      delayBetweenLines: 0
      soundID:
        ID: 1342177305
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3
      text: "Un p'tit coup de boost \xE7a peut pas m'faire de mal."
      characterCount: 50
      delayBetweenLines: 0
      soundID:
        ID: 1342177306
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 464e9e9c5413d1340bd1934a0c4149f5, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3
      text: "Ouhhhhh, \xE7a fait du bien !\n"
      characterCount: 27
      delayBetweenLines: 0
      soundID:
        ID: 1342177444
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 6.3
      text: "Incroyable ce petit truc, vous savez o\xF9 on peut en voler... EN ACHETER,
        je voulais dire en acheter...\n"
      characterCount: 102
      delayBetweenLines: 0
      soundID:
        ID: 1342177445
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 4.7
      text: "J'suis de nouveau op\xE9rationnel, j'suis de nouveau pr\xEAt \xE0 tout
