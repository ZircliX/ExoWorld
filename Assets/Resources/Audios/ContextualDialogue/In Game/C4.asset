  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 464e9e9c5413d1340bd1934a0c4149f5, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 5.2
      text: "Je lance puis je fait p\xE9ter, soit pas d\xE9\xE7u si \xE7a p\xE8te
        pas tout de suite Spikey.\n"
      characterCount: 80
      delayBetweenLines: 0
      soundID:
        ID: 1342177440
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 5.3
      text: "C4, un peu moins styl\xE9 que les autres mais tant que \xE7a p\xE8te,
        moi \xE7a me va.\n"
      characterCount: 75
      delayBetweenLines: 0
      soundID:
        ID: 1342177441
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 4.7
      text: "Un C4 qui explose, quel doux son \xE0 mes oreilles."
      characterCount: 48
