        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3
      text: 'Tout cela est plus excitant que je ne l''imaginais !

'
      characterCount: 52
      delayBetweenLines: 0
      soundID:
        ID: 1342177766
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 8538becf3d7dff243b44f593a4e788a8, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3
      text: 'Hmmm... C''est un peu trop facile comme boulot.

'
      characterCount: 47
      delayBetweenLines: 0
      soundID:
        ID: 1342177409
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 4.2
      text: "C'est quoi ces mutants fragiles ? \xC7a fait presque piti\xE9.\n"
      characterCount: 57
      delayBetweenLines: 0
      soundID:
        ID: 1342177410
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3
      text: "\xC7a devrait \xEAtre ill\xE9gal d'\xEAtre aussi forte."
      characterCount: 43
      delayBetweenLines: 0
      soundID:
        ID: 1342177411
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 464e9e9c5413d1340bd1934a0c4149f5, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3.5
      text: "H\xE9, putain vous avez vu \xE7a, vous avez vu \xE7a ?!!\n"
      characterCount: 48
      delayBetweenLines: 0
      soundID:
        ID: 1342177524
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 4.3
      text: "H\xE9, putain vous avez vu \xE7a, vous avez vu \xE7a ?!!\n"
      characterCount: 48
      delayBetweenLines: 0
      soundID:
        ID: 1342177525
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3.3
      text: "Maman serait si fi\xE8re de moi !!!\n"
      characterCount: 33
      delayBetweenLines: 0
      soundID:
        ID: 1342177526
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 4.8
      text: Spikey t'es vraiment le meilleur, le plus beau, le plus fort, je t'aime
        Spikey.
