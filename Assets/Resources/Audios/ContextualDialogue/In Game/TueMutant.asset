  - <CharacterData>k__BackingField: {fileID: 11400000, guid: bed7478a90a81034487b01a6fbd270ea, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3
      text: "Plut\xF4t toi que moi mon gar\xE7on, d\xE9sol\xE9.\n"
      characterCount: 39
      delayBetweenLines: 0
      soundID:
        ID: 1342177619
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3
      text: "Plut\xF4t toi que moi mon gar\xE7on, d\xE9sol\xE9.\n"
      characterCount: 39
      delayBetweenLines: 0
      soundID:
        ID: 1342177620
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3
      text: "Mouais, bon, j'ai d\xE9j\xE0 fait bien mieux.\n"
      characterCount: 40
      delayBetweenLines: 0
      soundID:
        ID: 1342177621
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3
      text: Va falloir faire plus pour me la prendre.
      characterCount: 41
      delayBetweenLines: 0
      soundID:
        ID: 1342177622
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 6907ab4dd1948334eabe022b53c8b49d, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3
      text: "Allez vous-en race m\xE9chante !\n"
