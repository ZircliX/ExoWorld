      soundID:
        ID: 1342177399
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3
      text: 'Qu''est ce que ce truc fait ici...

'
      characterCount: 34
      delayBetweenLines: 0
      soundID:
        ID: 1342177400
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3
      text: "S\xE9rieux qui a laiss\xE9 tra\xEEn\xE9 \xE7a l\xE0 ?\n"
      characterCount: 36
      delayBetweenLines: 0
      soundID:
        ID: 1342177401
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3.2
      text: Enfin un peu de culture... Pas que j'en ai besoin.
