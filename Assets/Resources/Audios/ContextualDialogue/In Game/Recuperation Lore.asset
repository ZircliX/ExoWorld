    - subtitleLifeTime: 4
      text: "Une parcelle du pass\xE9 se pr\xE9sente \xE0 moi... je l'accueille.\n"
      characterCount: 59
      delayBetweenLines: 0
      soundID:
        ID: 1342177756
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 4.2
      text: "Cela est un honneur... La m\xE9moire de ce lieu s'offre \xE0 moi.\n"
      characterCount: 60
      delayBetweenLines: 0
