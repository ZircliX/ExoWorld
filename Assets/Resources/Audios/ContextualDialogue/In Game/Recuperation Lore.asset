      delayBetweenLines: 0
      soundID:
        ID: 1342177402
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 464e9e9c5413d1340bd1934a0c4149f5, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 9.5
      text: "Hummmm, Ok, Hummmm, Ok, Ok, Hummmm, non j'd\xE9conne je sais pas lire.\n"
      characterCount: 68
      delayBetweenLines: 0
      soundID:
        ID: 1342177517
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 4.6
      text: "Peut \xEAtre une carte au tr\xE9sor pour un coffre rempli d'explosifs.\n"
      characterCount: 65
      delayBetweenLines: 0
      soundID:
        ID: 1342177518
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3
      text: "Les autres sauront s\xFBrement quoi en faire."
      characterCount: 42
      delayBetweenLines: 0
      soundID:
        ID: 1342177519
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
