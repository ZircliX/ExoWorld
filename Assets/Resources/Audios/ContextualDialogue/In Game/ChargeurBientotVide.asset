  clips:
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: bed7478a90a81034487b01a6fbd270ea, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3.1
      text: 'Depuis quand est ce que je tombe en rade de munition moi ?

'
      characterCount: 59
      delayBetweenLines: 0
      soundID:
        ID: 1342177595
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3
      text: "Bient\xF4t plus de balles, prenons garde."
      characterCount: 38
      delayBetweenLines: 0
      soundID:
        ID: 1342177596
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 6907ab4dd1948334eabe022b53c8b49d, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3
      text: "L'\xE9nergie de mon arme est faible.\n"
      characterCount: 34
      delayBetweenLines: 0
      soundID:
        ID: 1342177732
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3
      text: Avertissement, mes munitions sont faibles.
      characterCount: 42
      delayBetweenLines: 0
      soundID:
        ID: 1342177733
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 8538becf3d7dff243b44f593a4e788a8, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3.3
      text: "Presque \xE0 sec ? Comptez pas sur moi apr\xE8s \xE7a hein.\n"
      characterCount: 51
      delayBetweenLines: 0
      soundID:
        ID: 1342177373
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 4.3
      text: 'Moi ? A sec ...? Hooo, qui m''a pris mes balles ?!

'
      characterCount: 50
      delayBetweenLines: 0
      soundID:
        ID: 1342177374
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 4.3
      text: 'Moi ? A sec ...? Heuuu, qui m''a pris mes balles ?!

'
      characterCount: 51
      delayBetweenLines: 0
      soundID:
        ID: 1342177375
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3
      text: '"C''est quoi ces armes de merde qui se vident trop vite."'
      characterCount: 56
      delayBetweenLines: 0
      soundID:
        ID: 1342177376
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 464e9e9c5413d1340bd1934a0c4149f5, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3.6
      text: 'Il va me manquer des balles, va falloir passer au grenades.

'
      characterCount: 60
      delayBetweenLines: 0
      soundID:
        ID: 1342177493
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3
      text: "J'aurais d\xFB \xE9couter maman et prendre plus de balles."
      characterCount: 52
      delayBetweenLines: 0
      soundID:
        ID: 1342177494
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3
      text: "J'aurais d\xFB \xE9couter maman et prendre plus de balles."
      characterCount: 52
      delayBetweenLines: 0
      soundID:
        ID: 1342177495
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
