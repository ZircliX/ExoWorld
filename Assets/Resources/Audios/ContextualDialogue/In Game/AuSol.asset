    <Lines>k__BackingField:
    - subtitleLifeTime: 3
      text: "All\xF4\xF4\xF4 ? Je suis \xE0 terre l\xE0."
      characterCount: 28
      delayBetweenLines: 0
      soundID:
        ID: 1342177386
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3
      text: "Euuh.. Un petit coup de main s'il vous pla\xEEt ?"
      characterCount: 46
      delayBetweenLines: 0
      soundID:
        ID: 1342177387
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 4
      text: "Si jamais \xE7a vous int\xE9resse... j'ai besoin d'aide l\xE0 !"
