    <Lines>k__BackingField:
    - subtitleLifeTime: 5
      text: Je ne serai pas contre un petit coup de main pour qui aurait le temps,
        merci.
      characterCount: 77
      delayBetweenLines: 0
      soundID:
        ID: 1342177605
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3
      text: J'ai bien peur de devoir vous demander un peu d'aide.
      characterCount: 53
      delayBetweenLines: 0
      soundID:
        ID: 1342177606
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 6907ab4dd1948334eabe022b53c8b49d, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 4
      text: Secourez ! Il semble qu'ils veulent me manger !
