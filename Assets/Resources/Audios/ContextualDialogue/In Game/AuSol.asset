  - <CharacterData>k__BackingField: {fileID: 11400000, guid: bed7478a90a81034487b01a6fbd270ea, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 0
      text: Je ne serai pas contre un petit coup de main pour qui aurait le temps,
        merci.
      characterCount: 77
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 0
      text: J'ai bien peur de devoir vous demander un peu d'aide.
      characterCount: 53
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 6907ab4dd1948334eabe022b53c8b49d, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 0
      text: "Mes forces s'\xE9teignent... j'ai besoin de votre lumi\xE8re."
      characterCount: 55
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 0
      text: Faiblesse approche... je requiers votre assistance.
      characterCount: 51
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 0
      text: "J'ai le sentiment que mes m\xE9dicaments n'ont plus d'atteinte."
      characterCount: 60
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 8538becf3d7dff243b44f593a4e788a8, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 0
      text: "All\xF4\xF4\xF4 ? Je suis \xE0 terre l\xE0."
      characterCount: 28
      delayBetweenLines: 0
      soundID:
        ID: 1342177386
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 0
      text: "Euuh.. Un petit coup de main s'il vous pla\xEEt ?"
      characterCount: 46
      delayBetweenLines: 0
      soundID:
        ID: 1342177387
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 0
      text: "Si jamais \xE7a vous int\xE9resse... j'ai besoin d'aide l\xE0 !"
      characterCount: 54
      delayBetweenLines: 0
      soundID:
        ID: 1342177389
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 0
      text: "Euuh.. Un petit coup de main s'il vous pla\xEEt ?"
      characterCount: 46
      delayBetweenLines: 0
      soundID:
        ID: 1342177388
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 0
      text: "Si jamais \xE7a vous int\xE9resse... j'ai besoin d'aide l\xE0 !"
      characterCount: 54
      delayBetweenLines: 0
      soundID:
        ID: 1342177390
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 464e9e9c5413d1340bd1934a0c4149f5, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 0
      text: "\xC0 l'aide ! \xC0 l'aide ! Jeune demoiselle aurait besoin d'aide !"
      characterCount: 61
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 0
      text: Faudrait baisser les yeux et venir m'aider s'il vous plait !
      characterCount: 60
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 0
      text: "Hey ! Regarder en bas, je suis l\xE0 !"
      characterCount: 35
      delayBetweenLines: 0
      soundID:
        ID: 0
        _sourceAsset: {fileID: 0}
