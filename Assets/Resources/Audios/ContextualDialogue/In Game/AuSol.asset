    <Lines>k__BackingField:
    - subtitleLifeTime: 5
      text: "\xC0 l'aide ! \xC0 l'aide ! Une jeune demoiselle aurait besoin d'aide
        !"
      characterCount: 65
      delayBetweenLines: 0
      soundID:
