  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 464e9e9c5413d1340bd1934a0c4149f5, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 5.5
      text: "H\xE9 y'a un monstre qui m'a tir\xE9 une balle ? Ah non c'est juste
