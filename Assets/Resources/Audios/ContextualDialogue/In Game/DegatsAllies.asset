  - <CharacterData>k__BackingField: {fileID: 11400000, guid: bed7478a90a81034487b01a6fbd270ea, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3.7
      text: "\xC7a va pour cette fois mais faite attention o\xF9 vous tirez.\n"
      characterCount: 58
      delayBetweenLines: 0
      soundID:
        ID: 1342177616
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3
      text: 'Rien de trop grave mais faite attention.

'
      characterCount: 41
      delayBetweenLines: 0
      soundID:
        ID: 1342177617
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3.7
      text: "J'esp\xE8re que cet incident est le dernier."
      characterCount: 41
      delayBetweenLines: 0
      soundID:
        ID: 1342177618
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 6907ab4dd1948334eabe022b53c8b49d, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3.6
      text: "Vigilance ! Je re\xE7ois votre geste...\n"
      characterCount: 37
      delayBetweenLines: 0
      soundID:
        ID: 1342177759
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3
      text: "La trajectoire de votre geste m'a to\xFBch\xE9 !\n"
      characterCount: 43
      delayBetweenLines: 0
      soundID:
        ID: 1342177760
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 4
      text: "Alli\xE9 ! Je re\xE7ois votre impact ! Je me f\xE2che !"
      characterCount: 46
      delayBetweenLines: 0
      soundID:
        ID: 1342177761
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 8538becf3d7dff243b44f593a4e788a8, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3
      text: "Fais gaffe o\xF9 tu tires esp\xE8ce de trou d'uc!\n"
      characterCount: 44
      delayBetweenLines: 0
