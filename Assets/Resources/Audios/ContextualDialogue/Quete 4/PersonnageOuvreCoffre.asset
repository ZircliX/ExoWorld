  - <CharacterData>k__BackingField: {fileID: 11400000, guid: bed7478a90a81034487b01a6fbd270ea, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 2.9
      text: Juste une mallette... D'accord.
      characterCount: 31
      delayBetweenLines: 0
      soundID:
        ID: 1342177579
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 2.8
      text: J'imaginais... autre chose.
      characterCount: 27
      delayBetweenLines: 0
      soundID:
        ID: 1342177580
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 6907ab4dd1948334eabe022b53c8b49d, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3.2
      text: "Cet objet n'est gu\xE8re ce que mon imagination sugg\xE9rait."
      characterCount: 55
      delayBetweenLines: 0
      soundID:
        ID: 1342177714
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 4.4
      text: "Hmm... Sommes-nous certains que cet objet est celui demand\xE9 ?"
      characterCount: 61
      delayBetweenLines: 0
      soundID:
        ID: 1342177715
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 8538becf3d7dff243b44f593a4e788a8, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3.3
      text: Euuhh, une mallette ? On s'en fout nan ?
      characterCount: 40
      delayBetweenLines: 0
      soundID:
        ID: 1342177350
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 1.4
      text: Qu'est ce que-
      characterCount: 14
      delayBetweenLines: 0
      soundID:
        ID: 1342177351
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3.3
      text: Hein ? J'pensais que y'aurait au moins du fric la d'dans.
      characterCount: 57
      delayBetweenLines: 0
      soundID:
        ID: 1342177352
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 464e9e9c5413d1340bd1934a0c4149f5, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 5.2
      text: "Une bo\xEEte dans une bo\xEEte ? Surprise apr\xE8s surprise."
      characterCount: 51
      delayBetweenLines: 0
      soundID:
        ID: 1342177474
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 6.4
      text: "Et... c'est... une mallette ? J'suis d\xE9\xE7u ! Qu'est c'que j'suis
        d\xE9\xE7u !"
      characterCount: 70
      delayBetweenLines: 0
      soundID:
        ID: 1342177475
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
