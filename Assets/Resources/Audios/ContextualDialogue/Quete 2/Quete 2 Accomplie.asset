  - <CharacterData>k__BackingField: {fileID: 11400000, guid: bed7478a90a81034487b01a6fbd270ea, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 1.7
      text: "Je n'ai plus rien \xE0 faire ici."
      characterCount: 30
      delayBetweenLines: 0
      soundID:
        ID: 1342177571
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 1.9
      text: Mission accomplie avec brio.
      characterCount: 28
      delayBetweenLines: 0
      soundID:
        ID: 1342177572
        _sourceAsset: {fileID: 11400000, guid: 4984b444485d37e44800c8dbc385ccea, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 6907ab4dd1948334eabe022b53c8b49d, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 4.8
      text: "Le courant est retrouv\xE9, je suis satisfaite de notre collaboration."
      characterCount: 67
      delayBetweenLines: 0
      soundID:
        ID: 1342177708
        _sourceAsset: {fileID: 11400000, guid: 0ac6141356c332140b15e01263bd6990, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 8538becf3d7dff243b44f593a4e788a8, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 2.5
      text: "Et voil\xE0, tout remarche ! Merci qui ?\n"
      characterCount: 38
      delayBetweenLines: 0
      soundID:
        ID: 1342177338
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3
      text: 'On peut dire que ce travail est fait pour moi.

'
      characterCount: 47
      delayBetweenLines: 0
      soundID:
        ID: 1342177339
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 3.3
      text: "Moi j'dis... je m\xE9rite une augmentation."
      characterCount: 40
      delayBetweenLines: 0
      soundID:
        ID: 1342177340
        _sourceAsset: {fileID: 11400000, guid: 3d2a17dd7aa38d841a7e0919dd70839a, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
  - <CharacterData>k__BackingField: {fileID: 11400000, guid: 464e9e9c5413d1340bd1934a0c4149f5, type: 2}
    <Lines>k__BackingField:
    - subtitleLifeTime: 3.3
      text: 'Ok Spikey, t''as fini ton boulot ici.

'
      characterCount: 37
      delayBetweenLines: 0
      soundID:
        ID: 1342177466
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
    - subtitleLifeTime: 2.8
      text: "Ohh, dommage que \xE7a n'ait pas explos\xE9 !"
      characterCount: 39
      delayBetweenLines: 0
      soundID:
        ID: 1342177467
        _sourceAsset: {fileID: 11400000, guid: 6ed5981b9a651b442b19b34cbc974ea1, type: 2}
        <DebugObject>k__BackingField: {fileID: 0}
